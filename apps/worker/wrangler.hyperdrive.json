{
  "name": "hyperdrive-cfworker",
  "main": "src/index.ts",
  "compatibility_date": "2026-02-14",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "vars": {
    "DB_CLIENT": "hyperdrive",
    "NODE_ENV": "production",
    "JWT_SECRET": "YYYYYYYYYY",
    "DB_URL": "postgresql://agency_hyperdrive:XXXXXXXXXX@TTTTTTTTTT:5432/tenant_db",
    "POSTGREST_URL": "https://WWWWWWWWWW"
  },
  "hyperdrive": [
    {
      "binding": "HYPERDRIVE",
      "id": "UUUUUUUUUU"
    }
  ],
  "placement": {
    "host": "TTTTTTTTTT:5432"
  },
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    }
  }
}